## переменные сервера и api

# имя службы (контейнера) в докере
SERVICE_HOST_NAME=0.0.0.0
# порт хоста, на котором работает сервис
SERVICE_PORT=8081
# переулючатель режима логов
GIN_MODE=debug

## переменные сервиса

# ширина миниатюры по умолчанию
WIDTH_THUMBNAIL=150
# высота миниатюры по умолчанию
HEIGHT_THUMBNAIL=150

## переменные базы данных

# имя службы (контейнера) в докере
DB_HOST_NAME=dbPostgres
# порт, на котором сидит база данных
DB_PORT=5432
# имя базы данных
DB_NAME=db-postgres
# пароль базы данных
DB_PASSWORD=postgres
# имя пользователя базы данных
DB_USER=postgres

